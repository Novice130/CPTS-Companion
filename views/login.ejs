<style>
  .login-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 150px);
    padding: 2rem;
  }
  .login-card {
    max-width: 440px;
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--htb-border);
    border-radius: 12px;
    padding: 3rem 2.5rem;
    box-shadow: 0 10px 40px rgba(0,0,0,0.5);
    position: relative;
    overflow: hidden;
  }
  .login-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: var(--htb-green);
    box-shadow: 0 0 15px var(--htb-green);
  }
  .login-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .login-title {
    color: var(--text-primary);
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
  }
  .login-title svg {
    color: var(--htb-green);
  }
  .login-subtitle {
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .google-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
    padding: 14px;
    background: #ffffff;
    color: #1a1a1a;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    margin-bottom: 2rem;
    transition: all 0.2s ease;
    border: 1px solid transparent;
  }
  .google-btn:hover {
    background: #f1f1f1;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(255,255,255,0.1);
  }
  .divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .divider hr {
    flex: 1;
    border: none;
    border-top: 1px solid var(--htb-border);
  }
  .divider span {
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 500;
  }
  .form-group {
    margin-bottom: 1.5rem;
  }
  .form-group label {
    display: block;
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
    font-weight: 500;
  }
  .form-group input {
    width: 100%;
    padding: 12px 16px;
    background: var(--bg);
    border: 1px solid var(--htb-border);
    border-radius: 8px;
    color: var(--text-primary);
    font-size: 1rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .form-group input:focus {
    outline: none;
    border-color: var(--htb-green);
    box-shadow: 0 0 0 2px rgba(159, 239, 0, 0.2);
  }
  .submit-btn {
    width: 100%;
    padding: 14px;
    background: var(--htb-green);
    color: #000;
    border: none;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.2s;
    margin-top: 1rem;
  }
  .submit-btn:hover {
    background: #a9ff00;
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(159, 239, 0, 0.3);
  }
  .auth-toggle {
    text-align: center;
    margin-top: 2rem;
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .auth-toggle a {
    color: var(--htb-green);
    text-decoration: none;
    font-weight: 600;
    margin-left: 0.5rem;
  }
  .auth-toggle a:hover {
    text-decoration: underline;
  }
</style>

<div class="login-container">
  <div class="login-card">
    
    <div class="login-header">
      <h1 class="login-title">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
        CPTS Companion
      </h1>
      <p class="login-subtitle">Authenticate to access your workspace</p>
    </div>

    <!-- Google Sign-in -->
    <a href="#" id="google-signin-btn" class="google-btn"
       onclick="event.preventDefault(); fetch('/api/auth/sign-in/social', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ provider: 'google', callbackURL: window.location.origin + '/' }) }).then(r => r.json()).then(d => { if(d.url) window.location.href = d.url; else alert('Google login failed'); }).catch(e => alert('Network error'));">
      <svg width="22" height="22" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
      Continue with Google
    </a>

    <div class="divider">
      <hr>
      <span>OR USE EMAIL</span>
      <hr>
    </div>

    <!-- Email/Password Form -->
    <form id="authForm">
      <div class="form-group">
        <label>Email Address</label>
        <input type="email" id="email" required placeholder="hacker@example.com">
      </div>
      
      <div class="form-group">
        <label>Password</label>
        <input type="password" id="password" required minlength="8" placeholder="••••••••">
      </div>

      <!-- Name field (only for signup) -->
      <div class="form-group" id="nameField" style="display: none;">
        <label>Display Name</label>
        <input type="text" id="name" placeholder="John Doe">
      </div>

      <div id="authError" style="color: var(--htb-red); font-size: 0.9rem; margin-bottom: 1.5rem; text-align: center; display: none; background: rgba(234, 67, 53, 0.1); padding: 10px; border-radius: 6px; border: 1px solid rgba(234, 67, 53, 0.3);"></div>

      <button type="submit" id="submitBtn" class="submit-btn">
        Initialize Session
      </button>
    </form>

    <div class="auth-toggle">
      <span id="toggleText">Initial access required?</span>
      <a href="#" id="toggleAuth">Sign Up</a>
    </div>
  </div>
</div>

<script>
let isSignUp = false;

document.getElementById('toggleAuth').addEventListener('click', function(e) {
  e.preventDefault();
  isSignUp = !isSignUp;
  document.getElementById('nameField').style.display = isSignUp ? 'block' : 'none';
  document.getElementById('submitBtn').textContent = isSignUp ? 'Sign Up' : 'Sign In';
  document.getElementById('toggleText').textContent = isSignUp ? 'Already have an account?' : "Don't have an account?";
  document.getElementById('toggleAuth').textContent = isSignUp ? 'Sign In' : 'Sign Up';
  document.getElementById('authError').style.display = 'none';
});

document.getElementById('authForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const email = document.getElementById('email').value;
  const password = document.getElementById('password').value;
  const name = document.getElementById('name').value;
  const errorEl = document.getElementById('authError');

  try {
    const endpoint = isSignUp ? '/api/auth/sign-up/email' : '/api/auth/sign-in/email';
    const body = isSignUp ? { email, password, name } : { email, password };
    
    const res = await fetch(endpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });

    const data = await res.json();
    
    if (res.ok) {
      window.location.href = '/';
    } else {
      errorEl.textContent = data.message || 'Authentication failed. Try again.';
      errorEl.style.display = 'block';
    }
  } catch (err) {
    errorEl.textContent = 'Network error. Please try again.';
    errorEl.style.display = 'block';
  }
});
</script>
