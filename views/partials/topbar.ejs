<!-- Top Bar Partial -->
<header class="topbar">
  <div class="topbar-stats">
    <div class="stat-item">
      <span class="stat-icon">📊</span>
      <span class="stat-label">Progress</span>
      <span class="stat-value"><%= stats.overallProgress %>%</span>
    </div>
    <div class="stat-item">
      <span class="stat-icon">✅</span>
      <span class="stat-label">Exercises</span>
      <span class="stat-value"><%= stats.completedExercises %></span>
    </div>
    <div class="stat-item">
      <span class="stat-icon">🔄</span>
      <span class="stat-label">Review</span>
      <span class="stat-value"><%= nextReview %></span>
    </div>
  </div>
  
  <div class="topbar-actions" style="display: flex; align-items: center; gap: 1rem;">
    <button class="cmd-palette-btn" onclick="openCommandPalette()">
      <span>🔍</span>
      Quick search...
      <kbd>Ctrl</kbd><kbd>K</kbd>
    </button>
    
    <% if (typeof user !== 'undefined' && user) { %>
      <div class="user-profile" style="display: flex; align-items: center; gap: 1rem; padding-left: 1rem; border-left: 1px solid var(--htb-border);">
        <div style="display: flex; flex-direction: column; align-items: flex-end;">
          <span style="font-size: 0.85rem; font-weight: 600; color: var(--text-primary);"><%= user.name || 'Hacker' %></span>
          <span style="font-size: 0.75rem; color: var(--text-muted);"><%= user.email %></span>
        </div>
        <a href="/logout" title="Logout" style="color: var(--htb-red); text-decoration: none; padding: 0.4rem; border-radius: 4px; border: 1px solid transparent; transition: all 0.2s; display: flex; align-items: center; justify-content: center;" onmouseover="this.style.background='rgba(234, 67, 53, 0.1)'; this.style.borderColor='var(--htb-red)';" onmouseout="this.style.background='transparent'; this.style.borderColor='transparent';">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
        </a>
      </div>
    <% } %>
  </div>
</header>

<% if (typeof user === 'undefined' || !user) { %>
  <!-- Soft Login Curtain -->
  <div id="loginCurtain" style="position: fixed; top: 0; left: 0; width: 100%; height: 100vh; background: rgba(10, 10, 10, 0.85); backdrop-filter: blur(8px); z-index: 10000; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1);">
    <div style="background: var(--surface); border: 1px solid var(--htb-border); padding: 3rem; border-radius: 12px; max-width: 450px; text-align: center; transform: translateY(-30px); transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);" id="loginCurtainContent">
      <div style="font-size: 3rem; margin-bottom: 1rem;">👋</div>
      <h2 style="color: var(--text-primary); margin-bottom: 1rem;">Save Your Progress!</h2>
      <p style="color: var(--text-muted); line-height: 1.6; margin-bottom: 2rem;">
        You are currently exploring as a guest. To save your daily activities, study plans, and flashcard reviews, please log in with your account.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center;">
        <button onclick="document.getElementById('loginCurtain').style.opacity='0'; document.getElementById('loginCurtain').style.pointerEvents='none'; document.getElementById('loginCurtainContent').style.transform='translateY(-30px)';" style="background: transparent; color: var(--text-muted); border: 1px solid var(--htb-border); padding: 0.75rem 1.5rem; border-radius: 6px; cursor: pointer; font-weight: 500; transition: all 0.2s;">
          Maybe Later
        </button>
        <a href="/login" style="background: var(--htb-green); color: #000; text-decoration: none; padding: 0.75rem 1.5rem; border-radius: 6px; font-weight: 600; transition: all 0.2s; box-shadow: 0 0 15px rgba(159, 239, 0, 0.2);">
          Login Now
        </a>
      </div>
    </div>
  </div>

  <script>
    // Trigger the curtain animation shortly after page load
    setTimeout(() => {
      const curtain = document.getElementById('loginCurtain');
      const content = document.getElementById('loginCurtainContent');
      if (curtain && content) {
        curtain.style.opacity = '1';
        curtain.style.pointerEvents = 'all';
        content.style.transform = 'translateY(0)';
      }
    }, 1500); // Wait 1.5s before showing
  </script>
<% } %>
