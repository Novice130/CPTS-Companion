<!-- Top Bar Partial -->
<header class="topbar">
  <div class="topbar-stats">
    <div class="stat-item">
      <span class="stat-icon">📊</span>
      <span class="stat-label">Progress</span>
      <span class="stat-value"><%= stats.overallProgress %>%</span>
    </div>
    <div class="stat-item">
      <span class="stat-icon">✅</span>
      <span class="stat-label">Exercises</span>
      <span class="stat-value"><%= stats.completedExercises %></span>
    </div>
    <div class="stat-item">
      <span class="stat-icon">🔄</span>
      <span class="stat-label">Review</span>
      <span class="stat-value"><%= nextReview %></span>
    </div>
  </div>
  
  <div class="topbar-actions" style="display: flex; align-items: center; gap: 1rem;">
    <button class="cmd-palette-btn" onclick="openCommandPalette()">
      <span>🔍</span>
      Quick search...
      <kbd>Ctrl</kbd><kbd>K</kbd>
    </button>
    
    <% if (typeof user !== 'undefined' && user) { %>
      <div class="user-profile" style="display: flex; align-items: center; gap: 1rem; padding-left: 1rem; border-left: 1px solid var(--htb-border);">
        <div style="display: flex; flex-direction: column; align-items: flex-end;">
          <span style="font-size: 0.85rem; font-weight: 600; color: var(--text-primary);"><%= user.name || 'Hacker' %></span>
          <span style="font-size: 0.75rem; color: var(--text-muted);"><%= user.email %></span>
        </div>
        <a href="/logout" title="Logout" style="color: var(--htb-red); text-decoration: none; padding: 0.4rem; border-radius: 4px; border: 1px solid transparent; transition: all 0.2s; display: flex; align-items: center; justify-content: center;" onmouseover="this.style.background='rgba(234, 67, 53, 0.1)'; this.style.borderColor='var(--htb-red)';" onmouseout="this.style.background='transparent'; this.style.borderColor='transparent';">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
        </a>
      </div>
    <% } %>
  </div>
</header>
